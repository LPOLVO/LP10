ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        _G.IsResizing = true
        local startSize = Main.Size
        local dragStart = input.Position
        local conn
        conn = UserInputService.InputChanged:Connect(function(move)
            if move.UserInputType == Enum.UserInputType.MouseMovement or move.UserInputType == Enum.UserInputType.Touch then
                local delta = move.Position - dragStart
                Main.Size = UDim2.new(0, math.clamp(startSize.X.Offset + delta.X, Config.MinSize.X, Config.MaxSize.X), 0, math.clamp(startSize.Y.Offset + delta.Y, Config.MinSize.Y, Config.MaxSize.Y))
                currentSize = Main.Size
            end
        end)
        UserInputService.InputEnded:Connect(function(up)
            if up.UserInputType == Enum.UserInputType.MouseButton1 or up.UserInputType == Enum.UserInputType.Touch then
                _G.IsResizing = false
                conn:Disconnect()
            end
        end)
    end
end)

