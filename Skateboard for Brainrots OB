local function updateAutoFarm()
    local activeRarities = {}
    if autoSecret then table.insert(activeRarities, "Secret") end
    if autoCelestial then table.insert(activeRarities, "Celestial") end
    if autoDivine then table.insert(activeRarities, "Divine") end

    if #activeRarities > 0 then
        if farmRunning then return end
        farmRunning = true
        currentConnection = brainrotsFolder.DescendantAdded:Connect(function(descendant)
            if descendant:IsA("UIStroke") and descendant.Name == "UIStroke" and descendant.Parent and descendant.Parent.Name == "BrainrotName" then
                local displayName = descendant.Parent.Text
                if highTierData[displayName] and table.find(activeRarities, highTierData[displayName]) then
                    local model = descendant:FindFirstAncestorWhichIsA("Model")
                    if model then triggerBrainrot(model) end
                end
            end
        end)
    else
        farmRunning = false
        if currentConnection then currentConnection:Disconnect(); currentConnection = nil end
    end
end

