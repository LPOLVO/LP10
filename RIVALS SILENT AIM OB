-- [ 7. SILENT AIM LOGIC ]
local function getTarget(origin)
    if not Config.SilentAim then return nil end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local best, bestDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p == LP or not p.Character then continue end
        local head = p.Character:FindFirstChild("Head")
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end
        if (origin - head.Position).Magnitude > Config.MaxDist then continue end
        local sp, vis = Camera:WorldToViewportPoint(head.Position)
        if not vis then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < Config.FOV and d < bestDist then
            bestDist = d
            best = head
        end
    end
    return best
end

-- Hooking
if util then
    local origRay = util.Raycast
    util.Raycast = function(self, origin, direction, distance, ...)
        if Config.SilentAim then
            local target = getTarget(origin)
            if target then
                return origRay(self, origin, target.Position, distance, ...)
            end
        end
        return origRay(self, origin, direction, distance, ...)
    end
end

