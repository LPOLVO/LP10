        local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        circle.Color = getTarget(myRoot and myRoot.Position or Camera.CFrame.Position)
            and Color3.fromRGB(255, 50, 50) or Config.AccentColor
    end
end)

