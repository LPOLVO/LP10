local function SendLP10Notify(title, text, isError)
    local NotifyFrame = Instance.new("Frame")
    NotifyFrame.Name = "LP10_Notify"
    NotifyFrame.Parent = ScreenGui
    NotifyFrame.Size = UDim2.new(0, 260, 0, 70)
    NotifyFrame.Position = UDim2.new(1, 10, 1, -100)
    NotifyFrame.BackgroundColor3 = Config.BgColor
    NotifyFrame.BorderSizePixel = 0
    NotifyFrame.ZIndex = 200
    
    local UICorner = Instance.new("UICorner", NotifyFrame)
    UICorner.CornerRadius = UDim.new(0, 10)
    
    local Stroke = Instance.new("UIStroke", NotifyFrame)
    Stroke.Thickness = 2
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    Stroke.Color = isError and Color3.fromRGB(255, 60, 60) or Config.AccentColor

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Parent = NotifyFrame
    TitleLabel.Text = "  💎 " .. title:upper()
    TitleLabel.Size = UDim2.new(1, -10, 0, 30)
    TitleLabel.Position = UDim2.new(0, 0, 0, 5)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.TextColor3 = Stroke.Color
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextSize = 14
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.ZIndex = 201

    local DescLabel = Instance.new("TextLabel")
    DescLabel.Parent = NotifyFrame
    DescLabel.Text = text
    DescLabel.Size = UDim2.new(1, -20, 0, 30)
    DescLabel.Position = UDim2.new(0, 15, 0, 32)
    DescLabel.BackgroundTransparency = 1
    DescLabel.TextColor3 = Color3.new(1, 1, 1)
    DescLabel.Font = Enum.Font.GothamMedium
    DescLabel.TextSize = 12
    DescLabel.TextXAlignment = Enum.TextXAlignment.Left
    DescLabel.TextWrapped = true
    DescLabel.ZIndex = 201

    NotifyFrame:TweenPosition(UDim2.new(1, -280, 1, -100), "Out", "Back", 0.5, true)

    task.delay(4, function()
        if NotifyFrame then
            local tween = TweenService:Create(NotifyFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(1, 10, 1, -100)})
            tween:Play()
            tween.Completed:Wait()
            NotifyFrame:Destroy()
        end
    end)
end

