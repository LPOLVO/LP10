-- [[ DRAGGING ]]
local dragging, dragStart, startPos
Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = Main.Position end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

-- [[ LOGIC ]]
GetBtn.MouseButton1Click:Connect(function()
    setclipboard(Config.KeyLink)
    GetBtn.Text = "Copied!"
    task.wait(1)
    GetBtn.Text = "Get Key"
end)

SubmitBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == Config.CorrectKey then
        SubmitBtn.Text = "Verifying..."
        local TargetURL = _G.MainScript
        
        if TargetURL and TargetURL ~= "" then
            -- 1. أنميشن الخروج
            local out = TweenService:Create(Main, TweenInfo.new(0.5, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1})
            out:Play()
            
            out.Completed:Connect(function()
                -- 2. إخفاء الـ UI فوراً
                ScreenGui.Enabled = false
                
                -- 3. تـنفيذ السكربت الرئيسي بـ طـريقة مـضمونة (Deferred)
                task.defer(function()
                    local success, content = pcall(game.HttpGet, game, TargetURL)
                    if success then
                        -- مسح الكي سيستم نهائياً قبل التشغيل
                        ScreenGui:Destroy()
                        loadstring(content)()
                    else
                        warn("LP10 Error: Could not fetch script.")
                    end
                end)
            end)
        else
            SubmitBtn.Text = "Error: No URL!"
        end
    else
        KeyInput.Text = ""; KeyInput.PlaceholderText = "WRONG KEY!"; task.wait(1); KeyInput.PlaceholderText = "Enter Key..."
    end
end)
