local Config = {
    CorrectKey = "4fzx6ecbu1f6",
    KeyLink = "https://linkvertise.com/1418391/507cpxkNrsxX?o=sharing"
}

local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

-- [STRATEGY: PRE-FETCHING]
-- هاد المتغير غايحفظ الكود فـ الذاكرة باش ما يتسناش حتى تبرك على الزر
local CachedScript = nil
task.spawn(function()
    local success, content = pcall(function() return game:HttpGet(_G.MainScript) end)
    if success then CachedScript = content end
end)

local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "LP10_FastAuth"

-- ... (هنا كيبقى نفس الكود ديال الـ UI اللي عطينا فـ اللول) ...
-- غانمشي نيشان لـ Logic ديال الزر حيت تما فين درت التغيير:

SubmitBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == Config.CorrectKey then
        SubmitBtn.Text = "Executing..."
        
        -- 1. كنشوفو واش الكود ديجا واجد فـ الذاكرة
        if not CachedScript then
            -- إيلا مازال ما تيليشاركا، كنتسناوه واحد شوية
            local retry = 0
            while not CachedScript and retry < 10 do
                task.wait(0.2)
                retry = retry + 1
            end
        end

        if CachedScript then
            -- 2. أنميشن خفيفة باش ما نضيعوش الوقت
            TweenService:Create(Main, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}):Play()
            
            -- 3. التنفيذ الفوري
            task.spawn(function()
                local func = loadstring(CachedScript)
                if func then
                    -- كنخفيو الـ UI ونخدمو السكربت فالحين
                    ScreenGui.Enabled = false
                    func()
                    -- كنمحو الأثر مورا 3 ثواني باش ما نتقلوش الـ PC
                    task.wait(3)
                    ScreenGui:Destroy()
                end
            end)
        else
            SubmitBtn.Text = "Network Error!"
        end
    else
        -- Key Wrong
        KeyInput.Text = ""; KeyInput.PlaceholderText = "WRONG!"; task.wait(1); KeyInput.PlaceholderText = "Enter Key..."
    end
end)
