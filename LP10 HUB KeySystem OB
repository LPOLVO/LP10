local function StartLoadingSequence(callback)
    Title.Text = "🚀 INITIALIZING..."
    KeyInput.Visible = false
    GetBtn.Visible = false
    SubmitBtn.Visible = false
    
    local BarBg = Instance.new("Frame", Main)
    BarBg.Size = UDim2.new(0.85, 0, 0, 6)
    BarBg.Position = UDim2.new(0.075, 0, 0.55, 0)
    BarBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", BarBg)
    
    local BarFill = Instance.new("Frame", BarBg)
    BarFill.Size = UDim2.new(0, 0, 1, 0)
    BarFill.BackgroundColor3 = Config.AccentColor
    Instance.new("UICorner", BarFill)
    
    local Grad = Instance.new("UIGradient", BarFill)
    Grad.Color = ColorSequence.new(Config.AccentColor, Color3.fromRGB(0, 255, 255))

    local LoadingTween = TweenService:Create(BarFill, TweenInfo.new(1.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 1, 0)})
    LoadingTween:Play()
    
    LoadingTween.Completed:Connect(callback)
end

