local function StartLoading()
    Title.Text = "🚀 INITIALIZING..."
    KeyInput.Visible = false; GetBtn.Visible = false; SubmitBtn.Visible = false
    
    local BarBg = Instance.new("Frame", Main); BarBg.Size = UDim2.new(0.8, 0, 0, 8); BarBg.Position = UDim2.new(0.1, 0, 0.5, 0); BarBg.BackgroundColor3 = Color3.fromRGB(25, 25, 25); Instance.new("UICorner", BarBg)
    local BarFill = Instance.new("Frame", BarBg); BarFill.Size = UDim2.new(0, 0, 1, 0); BarFill.BackgroundColor3 = Config.AccentColor; Instance.new("UICorner", BarFill)
    local Percentage = Instance.new("TextLabel", Main); Percentage.Size = UDim2.new(1, 0, 0, 20); Percentage.Position = UDim2.new(0, 0, 0.6, 0); Percentage.BackgroundTransparency = 1; Percentage.TextColor3 = Color3.new(1, 1, 1); Percentage.Font = Enum.Font.Gotham; Percentage.TextSize = 14; Percentage.Text = "0%"

    local states = {"Loading Assets...", "Checking Database...", "Verifying Encryption...", "Preparing Hub..."}
    
    for i = 1, 100 do
        local alpha = i/100
        TweenService:Create(BarFill, TweenInfo.new(0.05), {Size = UDim2.new(alpha, 0, 1, 0)}):Play()
        Percentage.Text = i .. "%"
        if i % 25 == 0 then Title.Text = "🚀 " .. states[i/25] end
        task.wait(math.random(0.01, 0.05))
    end
    
    Title.Text = "✅ DONE!"
    task.wait(0.5)
end

