-- [[ 2. الـ PARTICLES SYSTEM ]]
local function SpawnParticle(parent)
    task.spawn(function()
        local p = Instance.new("Frame", parent)
        local size = math.random(2, 5)
        p.Name = "Particle"
        p.Size = UDim2.new(0, size, 0, size)
        p.Position = UDim2.new(math.random(), 0, 1, 5)
        p.BackgroundColor3 = Config.AccentColor
        p.BorderSizePixel = 0
        p.ZIndex = 2
        Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
        
        local tInfo = TweenInfo.new(math.random(2, 4), Enum.EasingStyle.Linear)
        local drift = math.random(-30, 30)
        local tween = TweenService:Create(p, tInfo, {
            Position = UDim2.new(p.Position.X.Scale, drift, -0.1, 0),
            BackgroundTransparency = 1
        })
        tween:Play()
        tween.Completed:Wait()
        p:Destroy()
    end)
end

